module quic.capsule_example

type VarInt = {
    prefix: bits[2],
    value: match prefix {
        0b00 => bits[6],
        0b01 => bits[14],
        0b10 => bits[30],
        0b11 => bits[62],
    },
}

capsule TlvContainer {
    type: VarInt,
    length: VarInt,
    payload: match type within length {
        0x01 => Data { value: u8 },
        _ => Unknown { data: bytes[remaining] },
    },
}
